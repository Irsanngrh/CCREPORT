# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# JANGAN pernah commit file .env ke dalam repositori

# ─── Database ─────────────────────────────────────────────────────────────────
# Format PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cc_report?schema=public"

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Gunakan string acak yang kuat (minimal 32 karakter)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="GANTI_DENGAN_STRING_RAHASIA_YANG_KUAT"
JWT_REFRESH_SECRET="GANTI_DENGAN_STRING_RAHASIA_BERBEDA_YANG_KUAT"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Frontend URL (untuk konfigurasi CORS) ────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://domain-anda.com
CLIENT_URL="http://localhost:5173"

# ─── Environment ──────────────────────────────────────────────────────────────
# development | production
NODE_ENV="development"
